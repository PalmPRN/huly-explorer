# Huly Platform Instance Configuration
HULY_URL=https://huly.app
HULY_WORKSPACE=my-workspace-name

# Authentication (Option 1: Email and Password)
HULY_EMAIL=your-email@example.com
HULY_PASSWORD=your-password

# Authentication (Option 2: Token)
# If HULY_TOKEN is set, it will be used instead of Email & Password
HULY_TOKEN=your-access-token
